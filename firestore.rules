rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function isAdminEmail() {
      return email() in [
        "joshua@asi-australia.com.au",
        "jaydan@asi-australia.com.au",
        "bobby@asi-australia.com.au"
      ];
    }

    function isAsiEmail() {
      return email() != null && email().matches(".*@asi-australia\\.com\\.au$");
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function userOrgId() {
      return userDoc().data.organizationId;
    }

    function isAdmin() {
      return signedIn() && userRole() == "admin";
    }

    function isTechnician() {
      return signedIn() && userRole() == "technician";
    }

    function isStaff() {
      return signedIn() && (isAdminEmail() || isAsiEmail() || isAdmin() || isTechnician());
    }

    // External auditor role — read-only access to IMS collections.
    // Access is time-limited: userDoc must have auditorTokenExpiresAt > now.
    function isAuditor() {
      return signedIn()
        && userRole() == "auditor"
        && userDoc().data.auditorTokenExpiresAt != null
        && request.time < timestamp.value(userDoc().data.auditorTokenExpiresAt);
    }

    // Read access for IMS-related collections — staff OR external auditors
    function canReadIms() {
      return isStaff() || isAuditor();
    }

    function hasOrg(orgId) {
      return signedIn() && userOrgId() != null && userOrgId() == orgId;
    }

    function isAsiOrg(orgId) {
      let org = get(/databases/$(database)/documents/contactOrganizations/$(orgId)).data;
      return org.category == "asi_staff"
        || (org.domains != null && org.domains.hasAny(["asi-australia.com.au"]));
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn() && (isAdminEmail() || isAsiEmail())
        && resource.data.role in ["admin", "technician", "contractor"];
      allow read: if isStaff() && resource.data.role == "client";
      allow read: if signedIn() && isAdminEmail()
        && resource.data.email in [
          "joshua@asi-australia.com.au",
          "jaydan@asi-australia.com.au",
          "bobby@asi-australia.com.au"
        ];
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /contactOrganizations/{orgId} {
      allow read: if isStaff() || hasOrg(orgId) || isAsiOrg(orgId) || !userExists();
      allow create: if signedIn() && (!userExists() || isStaff());
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /organizationContacts/{contactId} {
      allow read: if isStaff()
        || hasOrg(resource.data.organizationId)
        || isAsiOrg(resource.data.organizationId)
        || !userExists();
      allow create: if signedIn()
        && (!userExists() || hasOrg(request.resource.data.organizationId) || isStaff());
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isStaff() || hasOrg(resource.data.organizationId);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /inspections/{inspectionId} {
      allow read: if isStaff() || isAuditor() || hasOrg(resource.data.organizationId);
      allow create: if isStaff();
      allow update: if isStaff()
        || (signedIn()
          && hasOrg(resource.data.organizationId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "vehicleReports",
            "clientApprovalStatus",
            "clientApprovalUpdatedAt",
            "updatedAt"
          ]));
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if isStaff() || isAuditor() || hasOrg(resource.data.organizationId);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /worksRegister/{entryId} {
      allow read: if isStaff() || isAuditor() || hasOrg(resource.data.organizationId);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && request.auth.uid == resource.data.userId;
      allow create: if isStaff();
      allow update: if signedIn() && request.auth.uid == resource.data.userId;
      allow delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isStaff();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /userInvites/{inviteId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /clientInsights/{insightId} {
      allow read: if signedIn() && hasOrg(resource.data.organizationId);
      allow create, update, delete: if isAdmin();
    }

    match /goodsReceivedInspections/{inspectionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /prestartChecks/{checkId} {
      allow read: if canReadIms();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /imsDocuments/{docId} {
      allow read: if canReadIms();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();

      match /revisions/{revisionId} {
        allow read: if isAdmin() || isAuditor() || (isStaff() && resource.data.isCurrent == true);
        allow create: if isStaff();
        allow update: if isStaff();
        allow delete: if isAdmin();
      }
    }

    match /imsDocumentCounters/{counterId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /imsAudits/{auditId} {
      allow read: if canReadIms();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /automationAgents/{agentId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /stockItems/{itemId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /analyticsDaily/{docId} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /aiInsights/{docId} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /fleetVehicles/{vehicleId} {
      allow read: if isStaff() || hasOrg(resource.data.organizationId);
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /agentHubMessages/{messageId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /agentHubActions/{actionId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /agentHubDocs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /imsCorrectiveActions/{actionId} {
      allow read: if isAdmin() || isAuditor();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /imsIncidents/{incidentId} {
      allow read: if canReadIms();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /imsRiskRegister/{entryId} {
      allow read: if canReadIms();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /meetings/{meetingId} {
      allow read: if isStaff() || isAuditor();
      allow create: if isAdmin();
      allow update: if isStaff();
      allow delete: if false;
    }

    match /meetingTemplates/{templateId} {
      allow read: if isStaff() || isAuditor();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /meetingActions/{actionId} {
      allow read: if isStaff() || isAuditor();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if false;
    }

    match /filmInstallations/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /filmWarrantyInspections/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /filmWarrantyRegister/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /agentEmailAudit/{entryId} {
      // Sensitive audit trail — admin read only, client writes blocked.
      // All writes come from the Admin SDK via MCP endpoints.
      allow read: if isAdmin();
      allow write: if false;
    }

    match /secureCredentials/{credId} {
      // Server-side credentials (service account keys, etc.) — completely
      // blocked from all client access. Only the Admin SDK can read/write
      // these, which bypasses rules entirely.
      allow read, write: if false;
    }

    match /rndProjects/{projectId} {
      // R&D project register — Sophie Archer's domain. Staff can read
      // and create; updates allowed by staff (includes GUARDIAN audit
      // updates). Deletion restricted to admin for data integrity.
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /grantApplications/{grantId} {
      // Grant applications pipeline — commercially sensitive but staff
      // need visibility for cross-agent coordination (LEDGER for budget,
      // ATHENA for review, GUARDIAN for compliance).
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /rndOpportunityLog/{opportunityId} {
      // Opportunity signals dropped by any agent for Sophie to review.
      // Staff read/write so SENTINEL, VANGUARD, GUARDIAN etc. can all
      // contribute signals.
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /rndCounters/{counterId} {
      // Auto-numbering counters for RND / GRT / OPP document IDs.
      // Admin-only because they're system integrity artefacts.
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rndGrantProgrammes/{programmeId} {
      // Sophie's grant programme watchlist — reference data, staff
      // readable, writable for catalogue maintenance.
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /rndProjectNominations/{nominationId} {
      // Director nominates; Archer writes the pre-feas; Director
      // approves to convert into an RndProject. Staff read for
      // cross-agent visibility. Only admin can delete.
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // KPI Traceability Module (staff full access, clients can read own org data)
    match /fuelRecords/{docId} {
      allow read: if isStaff() || (signedIn() && resource.data.organizationId == userOrgId());
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /emissionsReports/{docId} {
      allow read: if isStaff() || (signedIn() && resource.data.organizationId == userOrgId());
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /telemetryReadings/{docId} {
      allow read: if isStaff() || (signedIn() && resource.data.organizationId == userOrgId());
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /maintenanceEvents/{docId} {
      allow read: if isStaff() || (signedIn() && resource.data.organizationId == userOrgId());
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /zebEnergyRecords/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /kpiSnapshots/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /satisfactionSurveys/{docId} {
      allow read: if isStaff() || (signedIn() && resource.data.organizationId == userOrgId());
      allow create: if signedIn();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Leads Register & Email Templates (admin/staff access)
    match /leadsRegister/{entryId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /emailTemplates/{templateId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Agent heartbeats — staff read, writes happen server-side only
    match /agentHeartbeats/{agentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // SHIELD / APEAX Distribution — admin + staff only.
    // All installer and public writes happen server-side via /api/apeax/* routes
    // using SHIELD_API_KEY or JWT session (never direct client writes).
    match /tradeAccounts/{accountId} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /apeaxOrders/{orderId} {
      allow read: if isStaff();
      allow write: if false;
    }

    match /apeaxSessions/{sessionId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
